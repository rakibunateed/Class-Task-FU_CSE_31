<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In</title>
  <link rel="stylesheet" href="Login.css" />
</head>

<body>
  <h2>Sign-In</h2>

  <form action="login.php" method="post">
    <table width="300">
      <tr>
        <td>
          <fieldset>
            <legend>Login</legend>

            Email:<br />
            <input
              type="email"
              name="email"
              size="30"
              placeholder="Your Email"
              required
            /><br /><br />

            Password:<br />
            <input
              type="password"
              name="password"
              size="30"
              placeholder="Your Password"
              required
            /><br /><br />

            <input type="submit" value="Sign In" />
            &nbsp;&nbsp;&nbsp;&nbsp;

            <a href="#">Forgot Password</a>

          </fieldset>
        </td>
      </tr>
    </table>
  </form>

</body>
</html>
